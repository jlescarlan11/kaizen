{
  "info": {
    "_postman_id": "03dcf87d-ad20-4b68-8c34-ccfc8cb97be9",
    "name": "Kaizen API Template",
    "description": "Template collection for Kaizen backend APIs.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "basic",
    "basic": [
      {
        "key": "username",
        "value": "{{basicAuthUsername}}",
        "type": "string"
      },
      {
        "key": "password",
        "value": "{{basicAuthPassword}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "basicAuthUsername",
      "value": "dev-user",
      "type": "string"
    },
    {
      "key": "basicAuthPassword",
      "value": "dev-password",
      "type": "string"
    },
    {
      "key": "googleAuthorizationCode",
      "value": "replace-me",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Probe Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/probe",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "probe"
              ]
            },
            "description": "Returns probe status for authenticated clients."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"status code is 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"status payload is ok\", function () {",
                  "  var body = pm.response.json();",
                  "  pm.expect(body.status).to.eql(\"ok\");",
                  "});"
                ]
              }
            }
          ],
          "response": []
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Start Google Sign-In",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/google/authorize",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "google",
                "authorize"
              ]
            },
            "description": "Redirects the client to Google's OAuth 2.0 consent screen for social sign-in."
          },
          "response": []
        },
        {
          "name": "Handle Google Sign-In Callback",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/google/callback?code={{googleAuthorizationCode}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "google",
                "callback"
              ],
              "query": [
                {
                  "key": "code",
                  "value": "{{googleAuthorizationCode}}"
                }
              ]
            },
            "description": "Exchanges Google's authorization code for tokens, creates or resolves a social account, and redirects to the configured post-auth destination."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Core APIs",
      "item": [
        {
          "name": "Budgets",
          "item": [
            {
              "name": "Save Smart Budgets",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"budgets\": [\n    {\n      \"categoryId\": 1,\n      \"amount\": 3000,\n      \"period\": \"MONTHLY\"\n    },\n    {\n      \"categoryId\": 2,\n      \"amount\": 1600,\n      \"period\": \"MONTHLY\"\n    },\n    {\n      \"categoryId\": 3,\n      \"amount\": 1000,\n      \"period\": \"MONTHLY\"\n    },\n    {\n      \"categoryId\": 4,\n      \"amount\": 1000,\n      \"period\": \"MONTHLY\"\n    }\n  ]\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/budgets/batch",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "api",
                    "budgets",
                    "batch"
                  ]
                },
                "description": "Saves the four smart budget allocations atomically for the authenticated user."
              },
              "response": []
            },
            {
              "name": "Create Budget",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"categoryId\": 1,\n  \"amount\": 3000,\n  \"period\": \"MONTHLY\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/budgets",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "api",
                    "budgets"
                  ]
                },
                "description": "Creates a single budget for the authenticated user."
              },
              "response": []
            }
          ]
        }
      ]
    },
    {
      "name": "Onboarding",
      "item": [
        {
          "name": "Get Onboarding Progress",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users/onboarding/progress",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "onboarding",
                "progress"
              ]
            },
            "description": "Retrieves the latest onboarding progress for the authenticated user. Returns 204 if no progress exists."
          },
          "response": []
        },
        {
          "name": "Update Onboarding Progress",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentStep\": \"BALANCE\",\n  \"balanceValue\": 4200,\n  \"budgetChoice\": \"default\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/onboarding/progress",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "onboarding",
                "progress"
              ]
            },
            "description": "Persists the current onboarding step and optional values for the authenticated user."
          },
          "response": []
        },
        {
          "name": "Delete Onboarding Progress",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users/onboarding/progress",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "onboarding",
                "progress"
              ]
            },
            "description": "Removes the persisted onboarding progress for the authenticated user. Returns 204 when no progress remains."
          },
          "response": []
        }
      ]
    }
  ]
}
