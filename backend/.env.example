# =============================================================================
# Kaizen Backend — Environment Variables Reference
# =============================================================================
# Copy this file to .env and fill in the values appropriate for your
# environment.  Lines marked "REQUIRED IN PROD" have NO safe default and
# MUST be explicitly set before starting in production or staging.
# Lines marked "DEV DEFAULTS OK" ship a sensible default that is acceptable
# for local development only — override them in prod/staging.
# =============================================================================

# -----------------------------------------------------------------------------
# Spring profile & server
# -----------------------------------------------------------------------------
SPRING_PROFILES_ACTIVE=dev              # DEV DEFAULTS OK  — use "prod" or "staging" in release envs
SERVER_PORT=8080                         # DEV DEFAULTS OK

# -----------------------------------------------------------------------------
# PostgreSQL — application datasource
# -----------------------------------------------------------------------------
DB_HOST=localhost                        # REQUIRED IN PROD (no default in prod/staging profile)
DB_PORT=55432                            # DEV DEFAULTS OK  — prod typically 5432
DB_NAME=kaizen                           # REQUIRED IN PROD
DB_USER=kaizen                           # REQUIRED IN PROD
DB_PASSWORD=kaizen                       # REQUIRED IN PROD — use a strong random password

# Embedded/testcontainers Postgres (local dev only — ignored in prod/staging)
DB_USE_EMBEDDED=false
DB_FALLBACK_TO_H2=false
DB_EMBEDDED_IMAGE=postgres:16-alpine
DB_EMBEDDED_NAME=kaizen_dev
DB_EMBEDDED_USER=kaizen
DB_EMBEDDED_PASSWORD=kaizen

# Optional for hosted Postgres providers that require SSL (e.g. Aiven, Render)
# SPRING_DATASOURCE_HIKARI_DATA_SOURCE_PROPERTIES_SSLMODE=require

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=localhost                     # REQUIRED IN PROD (no default in prod/staging profile)
REDIS_PORT=6379                          # DEV DEFAULTS OK

# Optional for hosted Redis providers requiring auth/TLS (e.g. Upstash, Render)
# SPRING_DATA_REDIS_PASSWORD=
# SPRING_DATA_REDIS_SSL_ENABLED=true

# -----------------------------------------------------------------------------
# Basic-auth credentials (actuator + admin endpoints)
# -----------------------------------------------------------------------------
APP_SECURITY_USER=dev-user               # REQUIRED IN PROD
APP_SECURITY_PASSWORD=dev-password       # REQUIRED IN PROD — use a strong random password

# -----------------------------------------------------------------------------
# OAuth / authentication
# -----------------------------------------------------------------------------

# Where the SPA lands after a successful sign-in / the sign-in page itself
APP_AUTH_POST_AUTH_REDIRECT_URI=http://localhost:5173/      # REQUIRED IN PROD
APP_AUTH_SCREEN_URI=http://localhost:5173/signin             # REQUIRED IN PROD

# Session lifetime in days (rolling)
APP_AUTH_SESSION_EXPIRY_DAYS=90          # DEV DEFAULTS OK — tune to your policy in prod

# APP_AUTH_TOKEN_ENCRYPTION_KEY_BASE64 — REQUIRED IN PROD/STAGING
# 256-bit AES key (32 raw bytes) encoded as Base64, used to encrypt stored
# OAuth access/refresh tokens at rest.
# Generate a fresh key with:   openssl rand -base64 32
# The application REFUSES TO START in prod/staging profiles if this variable
# is absent or still set to the public test default shipped in application.yml.
APP_AUTH_TOKEN_ENCRYPTION_KEY_BASE64=MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=   # DEV DEFAULTS OK — REPLACE IN PROD

# -----------------------------------------------------------------------------
# Google OAuth 2.0
# -----------------------------------------------------------------------------
GOOGLE_OAUTH_CLIENT_ID=google-client-id          # REQUIRED IN PROD
GOOGLE_OAUTH_CLIENT_SECRET=google-client-secret  # REQUIRED IN PROD
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8080/api/auth/google/callback  # REQUIRED IN PROD

# -----------------------------------------------------------------------------
# Auth rate limiting (B-SEC-4)
# -----------------------------------------------------------------------------
# APP_AUTH_RATE_LIMIT_CAPACITY: max requests per refill window per IP (default 10)
APP_AUTH_RATE_LIMIT_CAPACITY=10          # DEV DEFAULTS OK
# APP_AUTH_RATE_LIMIT_REFILL_SECONDS: refill window in seconds (default 60)
APP_AUTH_RATE_LIMIT_REFILL_SECONDS=60   # DEV DEFAULTS OK

# -----------------------------------------------------------------------------
# Validation
# -----------------------------------------------------------------------------
APP_VALIDATION_MAX_BALANCE_VALUE=999999999999.99  # DEV DEFAULTS OK
APP_VALIDATION_BUDGET_BALANCE_CONSTRAINT_ENABLED=true  # DEV DEFAULTS OK

# -----------------------------------------------------------------------------
# CORS — allowed origins for the SPA
# -----------------------------------------------------------------------------
# REQUIRED IN PROD — comma-separated list of allowed origins.
# Example: APP_CORS_ALLOWED_ORIGINS=https://app.kaizen.example,https://staging.kaizen.example
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173  # REQUIRED IN PROD (no safe wildcard)

# -----------------------------------------------------------------------------
# Sentry error monitoring
# -----------------------------------------------------------------------------
# SENTRY_DSN — REQUIRED IN PROD/STAGING
# Obtain your DSN from: Sentry dashboard → Settings → Projects → <project> → Client Keys (DSN).
# Leave blank locally; a blank DSN makes Sentry a no-op (no network calls).
SENTRY_DSN=                              # REQUIRED IN PROD
SENTRY_ENABLED=false                     # REQUIRED IN PROD — set to "true" in prod/staging
SENTRY_ENVIRONMENT=dev                   # REQUIRED IN PROD — e.g. "production" or "staging"
SENTRY_TRACES_SAMPLE_RATE=0.0            # DEV DEFAULTS OK — tune in prod (0.0–1.0, e.g. 0.1 = 10 %)
