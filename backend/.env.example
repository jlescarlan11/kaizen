# Spring profile and server
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080

# PostgreSQL
DB_HOST=localhost
DB_PORT=55432
DB_NAME=kaizen
DB_USER=kaizen
DB_PASSWORD=kaizen

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# App basic auth credentials (required for staging/prod)
APP_SECURITY_USER=dev-user
APP_SECURITY_PASSWORD=dev-password

# Optional for hosted Postgres providers that require SSL (e.g. Aiven)
# SPRING_DATASOURCE_HIKARI_DATA_SOURCE_PROPERTIES_SSLMODE=require

# Optional for hosted Redis providers requiring auth/TLS
# SPRING_DATA_REDIS_PASSWORD=
# SPRING_DATA_REDIS_SSL_ENABLED=true
