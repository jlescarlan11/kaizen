# Spring profile and server
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080

# PostgreSQL
DB_HOST=localhost
DB_PORT=55432
DB_NAME=kaizen
DB_USER=kaizen
DB_PASSWORD=kaizen
DB_USE_EMBEDDED=false
DB_FALLBACK_TO_H2=false
DB_EMBEDDED_IMAGE=postgres:16-alpine
DB_EMBEDDED_NAME=kaizen_dev
DB_EMBEDDED_USER=kaizen
DB_EMBEDDED_PASSWORD=kaizen

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# App basic auth credentials (required for staging/prod)
APP_SECURITY_USER=dev-user
APP_SECURITY_PASSWORD=dev-password

# Google OAuth sign-up
GOOGLE_OAUTH_CLIENT_ID=google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=google-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8080/api/auth/google/callback


APP_AUTH_POST_AUTH_REDIRECT_URI=http://localhost:5173/
APP_AUTH_SCREEN_URI=http://localhost:5173/signin
# 32-byte AES key encoded as Base64 for encrypting stored OAuth tokens
APP_AUTH_TOKEN_ENCRYPTION_KEY_BASE64=MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=

# CORS allowed origins (comma-separated). Required in staging/prod.
# Example: APP_CORS_ALLOWED_ORIGINS=https://app.kaizen.example,https://staging.kaizen.example
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# Optional for hosted Postgres providers that require SSL (e.g. Aiven)
# SPRING_DATASOURCE_HIKARI_DATA_SOURCE_PROPERTIES_SSLMODE=require

# Optional for hosted Redis providers requiring auth/TLS
# SPRING_DATA_REDIS_PASSWORD=
# SPRING_DATA_REDIS_SSL_ENABLED=true
