# Frontend API base URL for RTK Query (required, absolute http(s) URL).
# Vite reads this at build time (not runtime). Docker image builds must pass it via --build-arg.
VITE_API_BASE_URL=http://localhost:8080/api

# Sentry configuration — DSN must be supplied in release envs; leave blank locally so instrumentation stays opt-in.
VITE_SENTRY_DSN=
# Optional override for the environment tag written to Sentry; defaults to `import.meta.env.MODE` when unset.
VITE_SENTRY_ENV=

# URL or in-app route for the Smart Budget "Learn more" tooltip link.
# Set this once PRD Open Question 8 confirms whether the destination is (1) an in-app route,
# (2) a WebView to hosted docs, or (3) an external help center URL.
VITE_BUDGET_SUGGESTION_HELP_URL=
